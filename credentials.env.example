# credentials.env -- Lab environment credentials
#
# Copy this file to credentials.env and fill in your values:
#   cp credentials.env.example credentials.env
#   vi credentials.env
#
# This file is git-ignored. NEVER commit the real credentials.env.

# --- AWS credentials ---
export AWS_ACCESS_KEY_ID="<your-access-key-id>"
export AWS_SECRET_ACCESS_KEY="<your-secret-access-key>"
export AWS_DEFAULT_REGION="us-east-2"

# --- AWS account ---
export AWS_ACCOUNT_ID="<your-aws-account-id>"

# --- Route53 DNS ---
# The base domain (without leading dot) and its hosted zone ID.
# Example: if your sandbox domain is .sandbox1234.opentlc.com,
# set BASE_DOMAIN=sandbox1234.opentlc.com
export BASE_DOMAIN="<your-sandbox-domain>.opentlc.com"
# ROUTE53_HOSTED_ZONE_ID is resolved automatically from BASE_DOMAIN by the
# setup scripts — you do not need to provide it.

# --- Live Migration (optional) ---
# Set to "true" to provision AWS EFS for RWX VM root disks,
# enabling KubeVirt live migration. Increases AWS cost (~$0.30/GB-month).
# On-prem alternatives: OpenShift Data Foundation, NetApp ONTAP, Pure Storage.
export ENABLE_EFS_LIVE_MIGRATION="false"

# --- AWS web console (for reference only, not used by scripts) ---
# WEB_CONSOLE_URL="https://<account-id>.signin.aws.amazon.com/console"
# WEB_CONSOLE_USER="<console-username>"
# WEB_CONSOLE_PASSWORD="<console-password>"
